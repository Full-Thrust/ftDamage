{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Generated Fleet",
  "type": "object",
  "required": [
    "$schema",
    "name",
    "ships"
  ],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string",
      "const": "./fleet.schema.json"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "ships": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "classKey",
          "name",
          "position",
          "heading",
          "speed",
          "status"
        ],
        "additionalProperties": false,
        "properties": {
          "classKey": {
            "type": "string",
            "minLength": 1
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "position": {
            "type": "object",
            "required": [
              "x",
              "y"
            ],
            "additionalProperties": false,
            "properties": {
              "x": {
                "type": "integer",
                "minimum": 0
              },
              "y": {
                "type": "integer",
                "minimum": 0
              }
            }
          },
          "heading": {
            "type": "integer",
            "minimum": 1,
            "maximum": 12
          },
          "speed": {
            "type": "number",
            "minimum": 0
          },
          "status": {
            "type": "integer",
            "enum": [
              0,
              1,
              2
            ]
          }
        }
      }
    }
  }
}
